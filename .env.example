# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── HuggingFace ─────────────────────────────────────────
HUGGINGFACE_TOKEN=hf_...

# ── AWS S3 ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=agentic-rag-docs

# ── GCP ─────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ── Search (optional) ───────────────────────────────────
SERPAPI_KEY=...

# ── App Config ──────────────────────────────────────────
ENVIRONMENT=development   # development | production
LOG_LEVEL=INFO
API_PORT=8080
MAX_TOKENS=1024
TEMPERATURE=0.0

# ── Vector Store ────────────────────────────────────────
VECTORSTORE_PATH=data/vectorstore
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# ── Fine-tuned Model (optional) ─────────────────────────
LORA_MODEL_PATH=models/llama2-lora-finetuned
USE_LORA_MODEL=false
